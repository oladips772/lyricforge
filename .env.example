# ── LyricForge Environment Variables ──────────────────────────

# Stock footage APIs (get free keys below)
# Pexels:  https://www.pexels.com/api/  (free, 200 req/hr)
PEXELS_API_KEY=your_pexels_key_here

# Pixabay: https://pixabay.com/api/docs/ (free, 5000 req/hr)
PIXABAY_API_KEY=your_pixabay_key_here

# Whisper model size: tiny | base | small | medium | large-v3
# base = fast + good enough | large-v3 = best quality, slower
WHISPER_MODEL=base

# Server base URL (for building download links in responses)
BASE_URL=https://yourdomain.com

# Workers (how many concurrent jobs)
WORKERS=2
